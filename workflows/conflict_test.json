{
  "id": "conflict_test",
  "name": "Conflict Test - Serialization",
  "description": "Test file-level conflict serialization with two stages targeting same files",
  "version": "1.0.0",
  "tags": ["test", "conflict"],
  "inputs": {
    "required": ["project_path"],
    "optional": [],
    "schema": {
      "type": "object",
      "properties": {
        "project_path": {
          "type": "string",
          "description": "Absolute path to Swift project"
        }
      }
    }
  },
  "stages": [
    {
      "id": "scan_a",
      "agentId": "logic-agent",
      "task": "First scan of ALL Swift files - should acquire file locks",
      "dependsOn": [],
      "parallel": true,
      "targets": {
        "file_patterns": ["**/*.swift"]
      },
      "timeout_seconds": 300,
      "outputs": ["scan_a_result"]
    },
    {
      "id": "scan_b",
      "agentId": "logic-agent",
      "task": "Second scan of ALL Swift files - must wait for scan_a to release locks",
      "dependsOn": [],
      "parallel": true,
      "targets": {
        "file_patterns": ["**/*.swift"]
      },
      "timeout_seconds": 300,
      "outputs": ["scan_b_result"]
    }
  ],
  "max_parallel": 4,
  "timeout_minutes": 10,
  "retry_policy": {
    "max_retries": 0
  }
}
