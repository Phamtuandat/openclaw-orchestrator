{
  "models": {
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "YOUR_OPENROUTER_API_KEY",
        "auth": "api-key",
        "api": "openai-responses",
        "models": [
          {
            "id": "stepfun/step-3.5-flash:free",
            "name": "openrouter/stepfun/step-3.5-flash:free",
            "api": "openai-responses",
            "reasoning": false,
            "input": ["text"]
          },
          {
            "id": "deepseek/deepseek-coder-v2-lite-instruct:free",
            "name": "openrouter/deepseek/deepseek-coder-v2-lite-instruct:free",
            "api": "openai-responses",
            "reasoning": true,
            "input": ["text"]
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/stepfun/step-3.5-flash:free",
        "fallbacks": ["openrouter/deepseek/deepseek-coder-v2-lite-instruct:free"]
      },
      "workspace": "/absolute/path/to/workspace",
      "maxConcurrent": 4,
      "subagents": { "maxConcurrent": 4 }
    },
    "list": [
      {
        "id": "orchestrator-main",
        "name": "Orchestrator",
        "workspace": "/absolute/path/to/workspace",
        "skills": ["orchestrator", "planning"]
      },
      {
        "id": "logic-agent",
        "name": "Logic Agent",
        "workspace": "/absolute/path/to/workspace",
        "skills": ["logic", "viewmodel", "services"]
      },
      {
        "id": "ui-agent",
        "name": "UI Agent",
        "workspace": "/absolute/path/to/workspace",
        "skills": ["ui", "swiftui", "layout"]
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN",
      "allowFrom": ["YOUR_TELEGRAM_USER_ID"]
    },
    "whatsapp": {
      "enabled": false,
      "allowFrom": ["+84123456789"]
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    }
  }
}
