{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/workflow.schema.json",
  "title": "OpenClaw Workflow Definition",
  "description": "Schema for defining reusable workflow templates in OpenClaw orchestrator",
  "type": "object",
  "required": ["id", "name", "version", "stages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "description": "Unique workflow identifier (lowercase, underscores, hyphens)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable workflow name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "description": "Brief description of workflow purpose"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for categorization (e.g., safety, analysis, feature)"
    },
    "inputs": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required input parameter names"
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional input parameter names"
        },
        "schema": {
          "type": "object",
          "additionalProperties": true,
          "description": "JSON schema for input validation"
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "agentId", "task"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$",
            "description": "Unique stage identifier within workflow"
          },
          "agentId": {
            "type": "string",
            "description": "Agent to execute this stage"
          },
          "task": {
            "type": "string",
            "description": "Task description/prompt for the agent"
          },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Stage IDs that must complete before this stage starts"
          },
          "parallel": {
            "type": "boolean",
            "default": false,
            "description": "If true, this stage can run in parallel with others (subject to max_parallel)"
          },
          "targets": {
            "type": "object",
            "properties": {
              "file_patterns": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Glob patterns for files this stage should process"
              },
              "exclude_patterns": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Glob patterns to exclude"
              }
            }
          },
          "timeout_seconds": {
            "type": "number",
            "minimum": 1,
            "description": "Timeout for this stage (overrides agent default)"
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Output keys this stage produces (for later stages)"
          }
        }
      }
    },
    "safety_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "check"],
        "properties": {
          "name": { "type": "string" },
          "check": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["command", "script", "function"] },
              "command": { "type": "string" },
              "script": { "type": "string" },
              "function": { "type": "string" }
            }
          },
          "blockOnFailure": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "max_parallel": {
      "type": "number",
      "minimum": 1,
      "maximum": 20,
      "description": "Maximum number of stages that can run concurrently"
    },
    "timeout_minutes": {
      "type": "number",
      "minimum": 1,
      "description": "Overall workflow timeout"
    },
    "retry_policy": {
      "type": "object",
      "properties": {
        "max_retries": {
          "type": "number",
          "minimum": 0,
          "default": 2
        },
        "backoff": {
          "type": "string",
          "enum": ["linear", "exponential", "fixed"],
          "default": "exponential"
        },
        "fallback_models": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Model fallback chain if primary fails"
        }
      }
    },
    "on_complete": {
      "type": "object",
      "properties": {
        "notify": {
          "type": "boolean",
          "default": false
        },
        "persist_results": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
