{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": ".openclaw/dist",
    "rootDir": "src",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["src/core/**/*", "src/index.ts", "src/dashboard.ts", "src/api-server.ts", "src/workflows/**/*", "schemas/**/*"],
  "exclude": ["node_modules", "dist", "logs", "index", ".openclaw"]
}
